#
# Macro file for visualization with DAWNFILE
#
/control/verbose 2
/run/verbose 2
#
# Create a scene handler for DAWNFILE (file-based output)
#
/vis/open DAWNFILE
#
# Draw the world volume
#
/vis/drawVolume
#
# for drawing the tracks
#
/tracking/storeTrajectory 1
/vis/scene/add/trajectories

# Run one event
/run/beamOn 1
